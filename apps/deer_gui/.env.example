# Copy this file to .env and fill in your values.
# Variables set here are loaded at startup unless already set in the environment.

# Required: your LLM API key (must match the provider in config.yaml)
OPENAI_API_KEY=sk-your-key-here

# Optional: log level for deer_gui modules (debug, info, warn, error, trace)
DEER_GUI_LOG=info

# Optional: override the Deer Flow config file path
# DEER_FLOW_CONFIG_PATH=/path/to/config.yaml

# Optional: override the Python binary used by the bridge
# PYTHON_BIN=/path/to/python3
