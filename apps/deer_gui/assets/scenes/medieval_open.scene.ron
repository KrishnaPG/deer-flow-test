// Medieval Open World Scene
// A medieval landscape with terrain, vegetation, buildings, and NPCs
(
    name: "medieval_open",
    ambient_audio: "audio/ambient/medieval_forest.ogg",
    gltf_scene: null,
    theme: "medieval",
    generators: [
        // Medieval terrain with heightmap and texture splatting
        (
            generator: "medieval_terrain",
            params: Terrain(
                heightmap: "textures/terrain/heightmaps/medieval_valley.png",
                world_size: [2000.0, 2000.0],
                height_scale: 150.0,
                height_offset: 0.0,
                resolution: 64,
                chunk_size: 100.0,
                splat_mask: null,
                layer_textures: [
                    "textures/terrain/grass/grass_Color_512x512.png",
                    "textures/terrain/dirt/dirt_Color_512x512.png",
                    "textures/terrain/rock/rock_Color_512x512.png",
                    "textures/terrain/snow/snow_Color_512x512.png",
                ],
                uv_scale: 10.0,
                invert_heightmap: false,
            ),
        ),
        // Meadow vegetation
        (
            generator: "vegetation",
            params: Vegetation(
                biome: "Meadow",
                center: [0.0, 0.0, 0.0],
                radius: 800.0,
                density: 0.8,
                enable_wind: true,
                draw_distance: 600.0,
            ),
        ),
        // Forest vegetation on edges
        (
            generator: "vegetation",
            params: Vegetation(
                biome: "Forest",
                center: [400.0, 0.0, 400.0],
                radius: 300.0,
                density: 1.2,
                enable_wind: true,
                draw_distance: 500.0,
            ),
        ),
        // Ambient particles (dust motes in sunlight)
        (
            generator: "starfield",
            params: Starfield(
                count: 200,
                radius: 100.0,
                emissive: (1.0, 0.95, 0.8, 0.2),
            ),
        ),
    ],
)
