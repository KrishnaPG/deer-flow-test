// Medieval Meadow Scene
// A simple green meadow with procedural trees and a blue sky
SceneDescriptor(
    name: "medieval_open",
    ambient_audio: "audio/ambient/medieval_forest.ogg",
    gltf_scene: None,
    theme: "medieval",
    generators: [
        // Meadow terrain with heightmap and PBR textures
        (
            generator: "medieval_terrain",
            params: Terrain(
                heightmap: "textures/terrain/heightmaps/medieval_valley.png",
                world_size: (500.0, 500.0),
                height_scale: 20.0,
                height_offset: 0.0,
                resolution: 32,
                chunk_size: 100.0,
                splat_mask: None,
                layer_textures: (
                    Some("textures/terrain/grass/Grass003_1K-PNG_Color.png"),
                    None,
                    None,
                    None,
                ),
                uv_scale: 10.0,
                invert_heightmap: false,
            ),
        ),
        // Water system - lake/river
        (
            generator: "water",
            params: Water(
                bodies: [
                    (
                        id: "main_lake",
                        name: "Lake",
                        water_type: Lake,
                        position: (0.0, 5.0, 0.0),
                        size: (200.0, 200.0),
                        waves: (),
                        color: (0.1, 0.3, 0.5, 0.8),
                        opacity: 0.8,
                        has_collision: true,
                        depth: 5.0,
                    ),
                ],
            ),
        ),
        // Foliage system - meadow biome
        (
            generator: "foliage",
            params: Foliage(
                biome: "Meadow",
                wind_speed: 2.0,
                draw_distance: 500.0,
            ),
        ),
        // NPCs - small group of peasants
        (
            generator: "npcs",
            params: Npcs(
                spawns: [
                    (
                        npc_type: Peasant,
                        count: 5,
                        radius: 30.0,
                        center: (0.0, 10.0, 0.0),
                        behavior: Wander(radius: 20.0),
                        faction_id: None,
                    ),
                ],
            ),
        ),
        // Vegetation scatter (trees/bushes) - will be invisible until models exist
        (
            generator: "vegetation",
            params: Vegetation(
                biome: "Meadow",
                center: (0.0, 0.0, 0.0),
                radius: 150.0,
                density: 0.8,
                enable_wind: true,
                draw_distance: 300.0,
            ),
        ),
    ],
)
